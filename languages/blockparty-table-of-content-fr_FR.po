msgid "Table of content"
msgstr "Table des matières"

#: build/index.js:93 build/index.js:66
msgid "Content"
msgstr "Contenu"

#: build/index.js:95 build/index.js:68
msgid "Heading levels"
msgstr "Niveaux de titre"

#: build/index.js:96 build/index.js:69
msgid ""
"Heading levels to show in the table of content. Other individually activated "
"blocks may also appear."
msgstr ""
"Les niveaux de titre à afficher dans la table des matières. D’autres blocs "
"activés individuellement peuvent également apparaître."

#: build/index.js:104 build/index.js:85
msgid "Navigation label"
msgstr "Libellé de la navigation"

#: build/index.js:105 build/index.js:86
msgid "Not displayed, used for accessibility."
msgstr "Non affiché, utilisé pour l’accessibilité."

#: build/index.js:113 build/index.js:94
msgid "Colors"
msgstr "Couleurs"

#: build/index.js:119 build/index.js:99
msgid "Links color"
msgstr "Couleur des liens"

#: build/index.js:125 build/index.js:104
msgid "Links active color"
msgstr "Couleur des liens actifs"

#: build/index.js:128 build/index.js:108
msgid "Scroll behavior"
msgstr "Comportement au défilement"

#: build/index.js:130 build/index.js:110
msgid "Stick to top of screen"
msgstr "Épingler en haut de l’écran"

#: build/index.js:131 build/index.js:111
msgid "Should the table of content be sticky when scrolling?"
msgstr ""
"La table des matières doit-elle être épinglée (sticky) lors du défilement ?"

#: build/index.js:137 build/index.js:119
msgid "Top distance"
msgstr "Marge supérieure"

#: build/index.js:138 build/index.js:120
msgid "Distance from the top of the screen when scrolling."
msgstr "Distance depuis le haut de l’écran au défilement."

#: build/index.js:153 build/index.js:129
msgid "Highlight active link"
msgstr "Mettre en évidence le lien actif"

#: build/index.js:154 build/index.js:130
msgid ""
"Should the visible headings links be highlighted in the table of content?"
msgstr ""
"Les liens vers les titres visibles doivent-ils être mis en évidence dans la "
"table des matières ?"

#: build/index.js:165 build/index.js:145
msgid "No blocks found to show in Table of content"
msgstr "Aucun bloc trouvé à afficher dans la table des matières"

#: build/index.js:240 build/index.js:214
msgid "Display in table of content"
msgstr "Afficher dans la table des matières"

