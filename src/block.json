{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "blockparty/table-of-content",
  "version": "0.1.0",
  "title": "Table of content",
  "category": "widgets",
  "icon": "editor-ul",
  "description": "Display a table of content for a post.",
  "example": {},
  "supports": {
    "html": false
  },
  "textdomain": "blockparty-table-of-content",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "attributes": {
    "heading": {
      "type": "string"
    },
    "levels": {
      "type": "array",
      "default": [ 2 ]
    },
    "sticky": {
      "type": "boolean",
      "default": true
    },
    "stickyActive": {
      "type": "boolean",
      "default": true
    }
  }
}
